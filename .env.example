# ---------- API Security ----------
# Required — the server refuses to start without this (must be 16+ chars).
# Generate one with: openssl rand -hex 32
INTERNAL_API_KEY=

# Comma-separated list of origins allowed to call the API (both api.py and
# server.ts read this). Defaults to localhost:8000/3000 if unset.
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# Off (registration disabled) unless explicitly set to "true". With no gate,
# anyone who can reach this port — including everyone on a Tailscale tailnet,
# see README's "Remote access" section — could self-provision a working API
# key with full tool/integration access. Flip this on only for the window
# you actually want a new account created, then set it back to false.
ALLOW_REGISTRATION=false

# docker compose derives its project name from the current directory unless
# this is set — set it explicitly so a checkout in a differently-named
# folder doesn't silently spin up a second, disconnected stack.
COMPOSE_PROJECT_NAME=jarvis-os

# Optional. Not read directly by any code here, but Node/the OS respect it
# implicitly for Date/Intl formatting — set it if logs/timestamps should
# reflect your local timezone instead of UTC.
TZ=

# ---------- Local LLM (offline-first) ----------
# Used by the "llama-cpp" service in docker-compose.yml — bind-mounts
# HOST_MODEL_DIR (read-only) and serves LOCAL_MODEL_FILE from it over an
# OpenAI-compatible API at http://llama-cpp:8080 inside the Docker network.
# Point this at a directory containing a .gguf model you already have.
HOST_MODEL_DIR=./models
LOCAL_MODEL_FILE=your-model.Q4_K_M.gguf

# ---------- Jarvis files/notes ----------
# Used by src/integrations/files.ts — bind-mounted read-write into the api
# container at /jarvis-files. This is the ONLY folder Jarvis's file tools can
# ever read or write; nothing outside it is reachable, by construction, not
# just convention. Point this at any folder — it's created automatically if
# it doesn't exist yet.
JARVIS_FILES_DIR=./jarvis-notes
# Advanced/rarely needed: the container-internal mount point files.ts reads
# from — defaults to "/jarvis-files", matching the volume target above.
# Only set this if you've also changed that target in docker-compose.yml.
JARVIS_FILES_DIR_MOUNT=

# ---------- LLM ----------
# Optional cloud fallback — chat already works locally via the llama-cpp
# service above by default (see the Settings panel / localLlmEndpoint). Only
# set this if you want a cloud model available when the local one is down.
GEMINI_API_KEY=

# ---------- GitHub ----------
# Personal Access Token with repo scope, used by src/integrations/github.ts
GITHUB_TOKEN=
# Which repo the Coding department is allowed to open real PRs against —
# deliberately not a model-suppliable argument, see docs/superpowers/specs/
# 2026-07-21-agent-departments-design.md's Security section.
SELF_REPO_OWNER=
SELF_REPO_NAME=

# ---------- Google Calendar (OAuth) ----------
# Used by src/integrations/calendar.ts. See README's "Google Calendar setup"
# section for how to create these in Google Cloud. After setting them and
# restarting, visit GET /api/integrations/calendar/auth-url once to complete
# the one-time authorization — degrades to a clear "not configured"/"not
# authorized yet" error on every calendar route/tool until you do.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/calendar/callback

# ---------- Email (SMTP & IMAP) ----------
# Used by src/integrations/email.ts
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=
IMAP_HOST=
IMAP_PORT=

# ---------- Text-to-Speech ----------
# Used by src/integrations/tts.ts. Must be the internal Docker network address
# of the "tts" service defined in docker-compose.yml (http://tts:5050/...) —
# NOT the host-mapped localhost:5051 port, which the api container can't reach.
TTS_URL=http://tts:5050/v1/audio/speech
TTS_API_KEY=

# ---------- Speech-to-Text (offline-first) ----------
# Used by src/integrations/whisper.ts as the offline fallback for
# /api/voice-input when GEMINI_API_KEY isn't set or offline mode is on.
# Internal Docker network address of the "whisper-cpp" service — the model
# is baked into that image, no extra download needed.
WHISPER_URL=http://whisper-cpp:8081/inference

# ---------- PostgreSQL (pgvector) ----------
# Used by the "postgres" service in docker-compose.yml
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# Optional overrides — src/data/db.ts already defaults these to "postgres"
# (the Docker network service name) and 5432, which is correct for the
# bundled docker-compose.yml as-is. Only set these if you're pointing at a
# Postgres instance outside this compose stack.
POSTGRES_HOST=
POSTGRES_PORT=

# ---------- News ----------
# Used by src/integrations/news.ts. Free key from https://newsapi.org/
# Reachable via the get_news chat tool or GET /api/integrations/news/headlines
# and /search directly. Degrades to a clear "not configured" error if unset.
NEWS_API_KEY=

# ---------- Web Search (Brave) ----------
# Used by src/integrations/websearch.ts. Free key from
# https://brave.com/search/api/ (2,000 queries/month on the free tier).
# Reachable via the search_web chat tool or GET /api/integrations/websearch
# directly. Degrades to a clear "not configured" error if unset.
BRAVE_API_KEY=

# ---------- Web Push (PWA proactive notifications) ----------
# Generate with: node -e "console.log(JSON.stringify(require('web-push').generateVAPIDKeys()))"
# Identifies this server to browser push services (FCM, Mozilla's push
# service, etc.) — not a secret shared with any third party beyond that.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ---------- Currently unused ----------
# Not read by any code in this repo right now. Left here in case the
# features they map to get reintroduced — safe to ignore.
HARDWARE_PROFILE=
N_BATCH=
N_CTX=
N_THREADS=
OPENAI_API_KEY=
# Legacy Postgres var names — superseded by POSTGRES_USER/PASSWORD/DB above.
PG_DATABASE=
PG_HOST=
PG_PASSWORD=
PG_PORT=
PG_USER=
PG_USE_POSTGRES=
