# ---------- API Security ----------
INTERNAL_API_KEY=

# ---------- LLM ----------
# Optional cloud fallback — chat already works locally via Ollama by default
# (see the Settings panel / localLlmEndpoint). Only set this if you want a
# cloud model available when the local one is unreachable.
GEMINI_API_KEY=

# ---------- GitHub ----------
# Personal Access Token with repo scope, used by src/integrations/github.ts
GITHUB_TOKEN=

# ---------- Email (SMTP & IMAP) ----------
# Used by src/integrations/email.ts
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=
IMAP_HOST=
IMAP_PORT=

# ---------- Text-to-Speech ----------
# Used by src/integrations/tts.ts. Must be the internal Docker network address
# of the "tts" service defined in docker-compose.yml (http://tts:5050/...) —
# NOT the host-mapped localhost:5051 port, which the api container can't reach.
TTS_URL=http://tts:5050/v1/audio/speech
TTS_API_KEY=

# ---------- PostgreSQL (pgvector) ----------
# Used by the "postgres" service in docker-compose.yml
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ---------- Currently unused ----------
# Not read by any code in this repo right now. Left here in case the
# features they map to get reintroduced — safe to ignore.
BRAVE_API_KEY=
HARDWARE_PROFILE=
N_BATCH=
N_CTX=
N_THREADS=
OPENAI_API_KEY=
# Legacy Postgres var names — superseded by POSTGRES_USER/PASSWORD/DB above.
PG_DATABASE=
PG_HOST=
PG_PASSWORD=
PG_PORT=
PG_USER=
PG_USE_POSTGRES=
