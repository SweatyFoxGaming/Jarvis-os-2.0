# ---------- API Security ----------
# Required — the server refuses to start without this (must be 16+ chars).
# Generate one with: openssl rand -hex 32
INTERNAL_API_KEY=

# Comma-separated list of origins allowed to call the API (both api.py and
# server.ts read this). Defaults to localhost:8000/3000 if unset.
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# ---------- Local LLM (offline-first) ----------
# Used by the "llama-cpp" service in docker-compose.yml — bind-mounts
# HOST_MODEL_DIR (read-only) and serves LOCAL_MODEL_FILE from it over an
# OpenAI-compatible API at http://llama-cpp:8080 inside the Docker network.
# Point this at a directory containing a .gguf model you already have.
HOST_MODEL_DIR=./models
LOCAL_MODEL_FILE=your-model.Q4_K_M.gguf

# ---------- Jarvis files/notes ----------
# Used by src/integrations/files.ts — bind-mounted read-write into the api
# container at /jarvis-files. This is the ONLY folder Jarvis's file tools can
# ever read or write; nothing outside it is reachable, by construction, not
# just convention. Point this at any folder — it's created automatically if
# it doesn't exist yet.
JARVIS_FILES_DIR=./jarvis-notes

# ---------- LLM ----------
# Optional cloud fallback — chat already works locally via the llama-cpp
# service above by default (see the Settings panel / localLlmEndpoint). Only
# set this if you want a cloud model available when the local one is down.
GEMINI_API_KEY=

# ---------- GitHub ----------
# Personal Access Token with repo scope, used by src/integrations/github.ts
GITHUB_TOKEN=

# ---------- Email (SMTP & IMAP) ----------
# Used by src/integrations/email.ts
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=
IMAP_HOST=
IMAP_PORT=

# ---------- Text-to-Speech ----------
# Used by src/integrations/tts.ts. Must be the internal Docker network address
# of the "tts" service defined in docker-compose.yml (http://tts:5050/...) —
# NOT the host-mapped localhost:5051 port, which the api container can't reach.
TTS_URL=http://tts:5050/v1/audio/speech
TTS_API_KEY=

# ---------- Speech-to-Text (offline-first) ----------
# Used by src/integrations/whisper.ts as the offline fallback for
# /api/voice-input when GEMINI_API_KEY isn't set or offline mode is on.
# Internal Docker network address of the "whisper-cpp" service — the model
# is baked into that image, no extra download needed.
WHISPER_URL=http://whisper-cpp:8081/inference

# ---------- PostgreSQL (pgvector) ----------
# Used by the "postgres" service in docker-compose.yml
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ---------- Currently unused ----------
# Not read by any code in this repo right now. Left here in case the
# features they map to get reintroduced — safe to ignore.
BRAVE_API_KEY=
HARDWARE_PROFILE=
N_BATCH=
N_CTX=
N_THREADS=
OPENAI_API_KEY=
# Legacy Postgres var names — superseded by POSTGRES_USER/PASSWORD/DB above.
PG_DATABASE=
PG_HOST=
PG_PASSWORD=
PG_PORT=
PG_USER=
PG_USE_POSTGRES=
