# Virtual Environment
venv/
.venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Logs
logs/
*.log

# Database
/data/*.db
/data/*.sqlite
*.db
*.sqlite

# Environment variables
.env
.env.local
.env.*.local

# Local-only Docker services (home network integrations, e.g. Home Assistant)
# — deliberately never pushed to GitHub; auto-merged into docker-compose.yml
# by `docker compose` without any extra flag.
docker-compose.override.yml

# Model files (large)
models/*.gguf
models/*.bin

# Build artifacts
dist/
build/
*.spec

# IDE
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.part

# OS files
.DS_Store
Thumbs.db

# MyPy
.mypy_cache/
.pytest_cache/
.coverage

# Project specific — root-level runtime state (settings.json, learning.json).
# Must be anchored: a bare "data/" also matches src/data/, which is source.
/data/
tmp/

# Node dependencies
node_modules/

# Playwright MCP scratch output
.playwright-mcp/
